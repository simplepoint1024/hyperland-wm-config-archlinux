#!/usr/bin/env bash
set -euo pipefail
if command -v hyprlock >/dev/null 2>&1; then
  [ "${1-}" = "--print" ] && echo 'hyprlock' && exit 0
  exec hyprlock
fi
if command -v loginctl >/dev/null 2>&1; then
  [ "${1-}" = "--print" ] && echo 'loginctl lock-session' && exit 0
  exec loginctl lock-session
fi
echo 'No lock command available.' >&2
exit 1
